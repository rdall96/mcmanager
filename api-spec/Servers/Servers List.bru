meta {
  name: Servers List
  type: http
  seq: 3
}

get {
  url: {{base_url}}/api/v1/servers
  body: none
  auth: inherit
}

params:query {
  ~type: java
  ~type: java_quilt
  ~type: java_fabric
  ~type: java_forge
  ~type: java_neo_forged
  ~type: bedrock
}

script:post-response {
  if (res.status == 200 && res.body[0] != null) {
    bru.setEnvVar("server_id", res.body[0].id);
  }
}
