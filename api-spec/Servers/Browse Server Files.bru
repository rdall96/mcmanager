meta {
  name: Browse Server Files
  type: http
  seq: 16
}

get {
  url: {{base_url}}/api/v1/servers/{{server_id}}/files/browse
  body: none
  auth: inherit
}

params:query {
  ~path: configurations
  ~path: mods
  ~path: world/datapacks
  ~path: world
  ~path: world/playerdata
}

script:pre-request {
  if (bru.getEnvVar("server_id") == "") {
    throw "Missing server ID";
  }
}
