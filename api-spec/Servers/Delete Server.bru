meta {
  name: Delete Server
  type: http
  seq: 7
}

delete {
  url: {{base_url}}/api/v1/servers/{{server_id}}
  body: none
  auth: inherit
}

script:pre-request {
  if (bru.getEnvVar("server_id") == "") {
    throw "Missing server ID";
  }
}

script:post-response {
  if (res.status == 204) {
    bru.setEnvVar("server_id", "");
  }
}
