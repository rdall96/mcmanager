meta {
  name: Edit Server
  type: http
  seq: 6
}

put {
  url: {{base_url}}/api/v1/servers/{{server_id}}
  body: json
  auth: inherit
}

body:json {
  {
      "name": "Vanilla Survival",
      "port": 25551
  }
}

script:pre-request {
  if (bru.getEnvVar("server_id") == "") {
    throw "Missing server ID";
  }
}
