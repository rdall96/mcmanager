meta {
  name: Edit Server Properties
  type: http
  seq: 11
}

put {
  url: {{base_url}}/api/v1/servers/{{server_id}}/properties
  body: json
  auth: inherit
}

body:json {
  {
      "difficulty": 1,
      "motd": "MCManager QA tests",
      "spawn-protection": 0,
      "view-distance": 2,
      "white-list": true,
      "op-permission-level": 2
  }
}

script:pre-request {
  if (bru.getEnvVar("server_id") == "") {
    throw "Missing server ID";
  }
}
