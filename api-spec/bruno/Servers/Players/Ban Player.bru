meta {
  name: Ban Player
  type: http
  seq: 8
}

post {
  url: {{base_url}}/api/v1/servers/{{server_id}}/players/banned
  body: json
  auth: inherit
}

body:json {
  {
    "name": "rdall96",
    "reason": "Bad boy"
  }
}

script:pre-request {
  if (bru.getEnvVar("server_id") == "") {
    throw "Missing server ID";
  }
}
