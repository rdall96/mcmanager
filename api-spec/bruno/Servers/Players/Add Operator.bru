meta {
  name: Add Operator
  type: http
  seq: 2
}

post {
  url: {{base_url}}/api/v1/servers/{{server_id}}/players/operators
  body: json
  auth: inherit
}

body:json {
  {
    "name": "rdall96",
    "level": 1
  }
}

script:pre-request {
  if (bru.getEnvVar("server_id") == "") {
    throw "Missing server ID";
  }
}
