meta {
  name: Pardon Player
  type: http
  seq: 9
}

delete {
  url: {{base_url}}/api/v1/servers/{{server_id}}/players/banned
  body: json
  auth: inherit
}

body:json {
  {
    "name": "rdall96"
  }
}

script:pre-request {
  if (bru.getEnvVar("server_id") == "") {
    throw "Missing server ID";
  }
}
