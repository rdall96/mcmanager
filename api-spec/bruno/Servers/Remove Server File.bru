meta {
  name: Remove Server File
  type: http
  seq: 20
}

delete {
  url: {{base_url}}/api/v1/servers/{{server_id}}/files?path=icon.png
  body: none
  auth: inherit
}

params:query {
  path: icon.png
  ~path: world
}

script:pre-request {
  if (bru.getEnvVar("server_id") == "") {
    throw "Missing server ID";
  }
}
