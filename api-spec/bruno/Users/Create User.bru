meta {
  name: Create User
  type: http
  seq: 1
}

post {
  url: {{base_url}}/api/v1/users
  body: json
  auth: inherit
}

body:json {
  {
    "username": "testUser",
    "password": "hello@12345"
  }
}

script:post-response {
  if (res.status == 200) {
    bru.setEnvVar("user_id", res.body.id);
  }
}
