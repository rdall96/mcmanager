meta {
  name: Update Role
  type: http
  seq: 4
}

put {
  url: {{base_url}}/api/v1/roles/{{role_id}}
  body: json
  auth: inherit
}

body:json {
  {
    "name": "Default (updated)",
    "permissions": {
      "application": 1,
      "users": 5,
      "servers": 0
    }
  }
}

script:pre-request {
  if (bru.getEnvVar("role_id") == "") {
    throw "Missing role ID";
  }
}
