meta {
  name: Create Role
  type: http
  seq: 2
}

post {
  url: {{base_url}}/api/v1/roles
  body: json
  auth: inherit
}

body:json {
  {
    "name": "Default",
    "permissions": {
      "app": 3,
      "users": 1,
      "servers": 4095
    }
  }
}

script:post-response {
  if (res.status == 200) {
    bru.setEnvVar("role_id", res.body.id);
  }
}
