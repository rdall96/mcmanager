meta {
  name: Delete User
  type: http
  seq: 6
}

delete {
  url: {{base_url}}/api/v1/users/{{user_id}}
  body: none
  auth: inherit
}

script:pre-request {
  if (bru.getEnvVar("user_id") == "") {
    throw "Missing user ID";
  }
}

script:post-response {
  if (res.status == 204) {
    bru.setEnvVar("user_id", "");
  }
}
