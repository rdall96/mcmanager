meta {
  name: Login
  type: http
  seq: 1
}

post {
  url: {{base_url}}/auth/login
  body: formUrlEncoded
  auth: none
}

body:form-urlencoded {
  username: admin
  password: mcmanager
  ~username: testUser
  ~password: hello@12345
}

script:post-response {
  if (res.status == 200) {
    bru.setEnvVar("token", res.body.accessToken);
  }
  else {
    bru.setEnvVar("token", "");
  }
}
